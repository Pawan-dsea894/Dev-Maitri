        }
        if (apz.isNull(KendraApp.selectedCustomer.income)) {
            KendraApp.selectedCustomer.income = [];
        }
        if (apz.isNull(KendraApp.selectedCustomer.earnings)) {
            KendraApp.selectedCustomer.earnings = [];
