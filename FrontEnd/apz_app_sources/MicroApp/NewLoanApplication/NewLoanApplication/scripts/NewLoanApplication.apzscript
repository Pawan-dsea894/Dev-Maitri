            if(window.isCalcFromCustToLoanInput){
                setTimeout(function() {
                    apz.stopLoader();
	                ApzCOB.fnDisplayMsg("Member below 18 years.", "E");
	            }, 1000);
            }else{
                ApzCOB.fnDisplayMsg("Member below 18 years.", "E");
                KendraApp.selectedCustomer = {};
            }
