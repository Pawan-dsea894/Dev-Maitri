apz.app.NewLoanApplication.onClickPopoverClose = function() {
    $(".popover").fadeOut(200, function() {
        $(this).remove();
    });
}
apz.app.NewLoanApplication.hideAndShowIdentificationsCust = function(kendraId, customerId) {
    let kendraDts = kendraResponse.find((d) => d.kendraDtls.kendraId == kendraId);
    if (!apz.isNull(kendraDts.kendraDtls.customerDtls)) {
        let customerDts = kendraDts.kendraDtls.customerDtls.find((cust) = cust => cust.customerId == customerId);
        if ((customerDts.hasOwnProperty("mobileNum") && apz.isNull(customerDts.mobileNum) && customerDts.mobileNum === "")) {
            return false;
        } else if ((customerDts.hasOwnProperty("primaryId") && apz.isNull(customerDts.primaryId) && customerDts.primaryId === "")) {
            return false;
        } else if ((customerDts.hasOwnProperty("bankAccNo") && apz.isNull(customerDts.bankAccNo) && customerDts.bankAccNo === "")) {
            return false;
        } else if ((customerDts.hasOwnProperty("maritalStatus") && apz.isNull(customerDts.maritalStatus) && customerDts.maritalStatus ===
                "MARRIED" && apz.isNull(customerDts.depDocId))) {
            return false;
        }
    }
    return true;
}
apz.app.NewLoanApplication.paintDayList = function() {
    var weekDays = [{"dayDesc": "All"} , ...window.businessDays];
    apz.data.scrdata.NEWLOA__MahiDayList_Res = {};
    apz.data.scrdata.NEWLOA__MahiDayList_Res =  weekDays;
    apz.data.loadData("MahiDayList", 'NEWLOA');
    $("#NEWLOA__MahiDayList__o__NEWLOA__MahiDayList_Res__dayDesc_0").addClass('active');
}
apz.app.NewLoanApplication.paintMahiLeadDtlsBasedOnDay = function(pthis) {
    var id = pthis.id
    var dateStr,parts,leadsDate;
    var meetingDay = $('#' + pthis.id).text();
    $('.ett-para').removeClass('active');
    $(pthis).addClass('active');
    $("#NEWLOA__MahiDayList__o__NEWLOA__MahiDayList_Res__dayDesc_"+id).addClass('active');
    if(meetingDay === 'All'){
        $("#NEWLOA__NewLoanApplication__meetingDayDiv").addClass('sno');
    }else{
        $("#NEWLOA__NewLoanApplication__meetingDayDiv").removeClass('sno');
        $("#NEWLOA__NewLoanApplication__meetingDay").text(meetingDay)
    }
    var leadsBasedOnDay=[]
    //var prod ='-';
    if (KendraApp.MahiLeadList.length > 0) {
        KendraApp.MahiLeadList.forEach(k => {
            if((meetingDay).toLowerCase() === (dayMap[k.meetingDay]).toLowerCase() || meetingDay === 'All'){
                // KendraApp.ProductResponse.forEach(item =>{
                //     if(item.productDtls.productId === k.mahiLeads[0].productName){
                //         prod = item.productDtls.shortDesc
                //     }
                // })
                dateStr = k.mahiLeads[0].leadUpdateDate
                parts = dateStr.split("-");
                leadsDate = parts[2] + "-" + parts[1] + "-" + parts[0];
                var obj={
                'customerName':k.customerName,
                'customerId':k.customerId,
                'kendraName':k.kendraName,
                'leadUpdateDate':leadsDate,
                'leadStatus':k.mahiLeads[0].leadStatus,
                'eligibleLoanAmount':k.mahiLeads[0].eligibleLoanAmount,
                'productName':k.mahiLeads[0].productName
                }
                leadsBasedOnDay.push(obj)
            }
        });
        if(leadsBasedOnDay.length > 0){
            apz.data.scrdata.NEWLOA__MahiLeadList_Res = {};
            apz.data.scrdata.NEWLOA__MahiLeadList_Res.Lead =  leadsBasedOnDay;
            $('#NEWLOA__NewLoanApplication__noRecord').addClass('sno');
        }else{
            apz.data.scrdata.NEWLOA__MahiLeadList_Res = {};
            $('#NEWLOA__NewLoanApplication__noRecord').removeClass('sno');
        }
        apz.data.loadData('MahiLeadList', apz.currAppId);
    } else {
        apz.data.scrdata.NEWLOA__MahiLeadList_Res = {};
        $('#NEWLOA__NewLoanApplication__noRecord').removeClass('sno');
    }
   
}    
apz.app.NewLoanApplication.paintMahiLeadList = function() { 
    apz.data.scrdata.NEWLOA__MahiLeadList_Res = {};
    apz.data.scrdata.NEWLOA__MahiLeadList_Res.Lead =  mahiLeadListDtls;
    apz.data.loadData("MahiLeadList", 'NEWLOA');
}
apz.app.NewLoanApplication.MahiBackNavigation = function(params) {
    if(params === 'viewMore'){
        window.MahiLeadFromDashboard = false;
		window.MahiLeadFromList = false;
        ApzCOB.backNavigation();
    }else if(params === 'leadDtls'){
        if(isMahiLeadFromDashboardToDtls){
            isMahiLeadFromDashboardToDtls = false;
            ApzCOB.backNavigation();
        }else if(isMahiLeadFromListToDtls){
            isMahiLeadFromListToDtls = false;
            $("#NEWLOA__NewLoanApplication__leadDtlsDiv").addClass('sno');
            apz.app.NewLoanApplication.loadMahiLeadDiv('leadFromViewMore')
        }else{
            ApzCOB.backNavigation();
        }
    }
}
apz.app.NewLoanApplication.onSearchLeads = function(pthis) {
    var searchText = $("#" + pthis.id).val();
    var searchResult = [];
    searchResult = ApzCOB.arraySearch(searchText, mahiLeadListDtls, ["customerName", "customerId","kendraName"],'NEWLOA__MahiLeadList_Res', "", '', '');
    searchResult.forEach((item, index) => {
        item.rowNo = index;
    });
    if (searchResult.length === 0) {
        $("#" + newLoanscreenId + "noRecord").removeClass("sno");
        $("#" + newLoanscreenId + "ct_lst_7").addClass("sno");
    } else {
        $("#" + newLoanscreenId + "noRecord").addClass("sno");
        $("#" + newLoanscreenId + "ct_lst_7").removeClass("sno");
    }
    if (searchText.length === 0) {
        apz.data.scrdata.NEWLOA__MahiLeadList_Res.Lead = mahiLeadListDtls;
        apz.data.loadData("MahiLeadList", 'NEWLOA');
        $("#" + newLoanscreenId + "noRecord").addClass("sno");
        $("#" + newLoanscreenId + "ct_lst_7").removeClass("sno");
    } else {
        apz.data.scrdata.NEWLOA__MahiLeadList_Res = {};
        apz.data.scrdata.NEWLOA__MahiLeadList_Res.Lead = searchResult;
        apz.data.loadData("MahiLeadList", 'NEWLOA');
    }
}
apz.app.NewLoanApplication.paintLeadDtls = function() {
    let dateStr = mahiLeadData?.mahiLeads[0].dateSubmitted
    let parts = dateStr.split("-");
    let leadsDate = parts[2] + "-" + parts[1] + "-" + parts[0];
    $("#NEWLOA__NewLoanApplication__leadCustName").text(mahiLeadData?.customerName)
    $("#NEWLOA__NewLoanApplication__leadgroupId").text(mahiLeadData?.groupId)
    $("#NEWLOA__NewLoanApplication__leadKendraid").text(mahiLeadData?.kendraId)
    $("#NEWLOA__NewLoanApplication__leadCustId").text(mahiLeadData?.customerId)
    $("#NEWLOA__NewLoanApplication__leadProduct").text(mahiLeadData?.mahiLeads[0].productName)
    $("#NEWLOA__NewLoanApplication__leadPurpose").text(mahiLeadData?.mahiLeads[0].loanPurpose)
    $("#NEWLOA__NewLoanApplication__leadEligibleAmt").text(mahiLeadData?.mahiLeads[0].eligibleLoanAmount)
    $("#NEWLOA__NewLoanApplication__leadSubmittedDate").text(leadsDate)
    $("#NEWLOA__NewLoanApplication__leadTransactionId").text(mahiLeadData?.mahiLeads[0].transactionId)
    $("#NEWLOA__NewLoanApplication__leadSatus").text(mahiLeadData?.mahiLeads[0].leadStatus)
}
apz.app.NewLoanApplication.proceedLead = function (){
    $('#scr__NEWLOA__DeoCustDetails__main').addClass('sno');
    var params = {
        ...KendraApp.selectedKendra,
        sourceScreen: 'DeoLeads'
    };
    ApzCOB.launchMicroApp("NEWLOA", "AddLoanDetails", "APZCBO__BaseScreens__STAGE1", params);
}
var rejectionReasons = ['Collection Issue', 'Kendra Issue', 'Low Attendance in Kendra Meeting','Member Issue', 'Others'];
apz.app.NewLoanApplication.rejectLeads = function() {
    ApzCOB.toggleModal(newLoanscreenId + "rejectReasonModal");
    let paintData = rejectionReasons.map((data) => ({
        reason: data
    }));
    apz.data.scrdata.NEWLOA__MahiRejectReason_Res = {};
    apz.data.scrdata.NEWLOA__MahiRejectReason_Res.Reject = paintData;
    apz.data.loadData("MahiRejectReason", "NEWLOA");
}
var leadRajectReason='';
apz.app.NewLoanApplication.onClickOfRejectionCheckBox = function (pthis) {
    var id = parseInt($(pthis).attr('rowno'));
    leadRajectReason=''
    if (apz.data.scrdata.NEWLOA__MahiRejectReason_Res.Reject[id].reason === 'Others' && $("#" + pthis.id).prop("checked")) {
        $(`#${'NEWLOA__NewLoanApplication__rejectReasonList_row_'+id} #${'NEWLOA__NewLoanApplication__sc_row_138_row'}`).removeClass('sno');
    } else if (apz.data.scrdata.NEWLOA__MahiRejectReason_Res.Reject[id].reason === 'Others' && (!$("#" + pthis.id).prop("checked"))) {
       $(`#${'NEWLOA__NewLoanApplication__rejectReasonList_row_'+id} #${'NEWLOA__NewLoanApplication__sc_row_138_row'}`).removeClass('sno');
    }
    apz.data.scrdata.NEWLOA__MahiRejectReason_Res.Reject.forEach((data,index) => {
        if (index !== parseInt(id)) {
            //$("#" + newLoanscreenId + "el_cbx_1_" + index).prop("checked", false);
            $(`#${'NEWLOA__NewLoanApplication__rejectReasonList_row_'+index} #${'NEWLOA__NewLoanApplication__el_cbx_1_'+index}`).prop("checked", false);
            $(`#${'NEWLOA__NewLoanApplication__rejectReasonList_row_'+index} #${'NEWLOA__NewLoanApplication__sc_row_138_row'}`).addClass('sno');
        }
    })
};
apz.app.NewLoanApplication.submitReson = function() {
    let reason;
    apz.data.scrdata.NEWLOA__MahiRejectReason_Res.Reject.forEach((item, index) => {
        var isChecked = $(`#${'NEWLOA__NewLoanApplication__rejectReasonList_row_'+index} #${'NEWLOA__NewLoanApplication__el_cbx_1_'+index}`).prop("checked");
        if (isChecked && (item.reason !== 'Others')) {
            reason = item.reason;
        } else if (isChecked && item.reason === 'Others') {
            reason = $(`#${'NEWLOA__NewLoanApplication__rejectReasonList_row_'+index} #${'NEWLOA__NewLoanApplication__el_txa_1_'+index}`).val();
        }
    })
    return reason;
}
var mahiLeadRejectReason = '';
apz.app.NewLoanApplication.onRejectedLead = function () {
    mahiLeadRejectReason = apz.app.NewLoanApplication.submitReson();
    if(apz.isNull(mahiLeadRejectReason)){
        ApzCOB.toggleModal(newLoanscreenId + "rejectReasonModal");
        ApzCOB.fnDisplayMsg("Reason is not selected!", "I", apz.app.NewLoanApplication.cancelCB);
        return;
    }
    ApzCOB.toggleModal(newLoanscreenId + "rejectReasonModal");
     var req = {
        "apiRequest": {
            "interfaceName": "UpdateMahiLeadsStatus",
            "appId": "APZCBO",
            "userId": LoggedInUserDetails.userID,
            "requestObj": {
                "transactionId": $('#NEWLOA__NewLoanApplication__leadTransactionId').text(),
                "reason": mahiLeadRejectReason,
                "status": "Rejected"
            }
        }
    }
    apz.startLoader()
    ApzCOB.serverBuildParam(gAppId, "UpdateMahiLeadsStatus", "N", "N", req, false, apz.app.NewLoanApplication.onRejectedLeadCB);
}
apz.app.NewLoanApplication.onRejectedLeadCB = function(params) {
    try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            if (!apz.isNull(params.res.APZCBO__UpdateMahiLeadsStatus_Res.apiResponse.ResponseBody.responseObj)) {
                 apz.stopLoader();
                let response = JSON.parse(params.res.APZCBO__UpdateMahiLeadsStatus_Res.apiResponse.ResponseBody.responseObj);
                if(response.message === 'Status changed'){
                    $("#NEWLOA__NewLoanApplication__leadDtlsDiv").addClass('sno');
                    $("#NEWLOA__NewLoanApplication__viewMoreDiv").addClass('sno');
                    $("#NEWLOA__NewLoanApplication__rejCustName").text(`${mahiLeadData?.customerName} ₹ (${mahiLeadData?.mahiLeads[0]?.eligibleLoanAmount} ${mahiLeadData?.mahiLeads[0]?.productName})`)
                    $("#NEWLOA__NewLoanApplication__rejTxnId").text(`TXN ID: ${mahiLeadData?.mahiLeads[0]?.transactionId}`)
                    $("#NEWLOA__NewLoanApplication__rejRejectReason").text(`${mahiLeadRejectReason}`)
                    $("#NEWLOA__NewLoanApplication__rejectDiv").removeClass('sno');
                    KendraApp.MahiLeadList.forEach(item => {
                        if(item.customerId === mahiLeadData.customerId){
                            item.mahiLeads[0].leadStatus = 'Rejected';
                        }
                    });

                }else{
                    apz.stopLoader();
                    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
                }
                
            } else {
                apz.stopLoader();
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
            }
        } else{
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    }
};
apz.app.NewLoanApplication.rejectViewMore = function() {
    if ($("#" + newLoanscreenId + "sc_row_130").hasClass("sno")) {
        $("#" + newLoanscreenId + "sc_row_130").removeClass("sno");
    } else {
        $("#" + newLoanscreenId + "sc_row_130").addClass("sno");
    }
}
apz.app.NewLoanApplication.cancelCB = function(params){
    if (params.choice === true) {
        ApzCOB.toggleModal(newLoanscreenId + "rejectReasonModal");
    }
}
apz.app.NewLoanApplication.selectCustomer = function(pthis) {
    event.preventDefault();
    event.stopPropagation();
    let rowNo = $(pthis).attr('rowno');
    var selectedLead = '';
    var custId = apz.data.scrdata.NEWLOA__MahiLeadList_Res.Lead[rowNo].customerId
    KendraApp.MahiLeadList.forEach(k=>{
        if(custId === k.customerId){
            selectedLead = k
        }
    })
    isMahiLeadFromListToDtls = true;
    window.MahiLeadFromList = true;
    window.MahiLeadFromDashboard = false;
    KendraApp.selectedCustomer = selectedLead;
    if((selectedLead.mahiLeads[0].leadStatus).toLowerCase() == 'pending'){
        isApplyingLoanFromMahiLeadDtls = true;
        apz.app.KmLeads.getKendraDetail(KendraApp.selectedCustomer)
        apz.app.KmLeads.selectLoan();
        $("#" + newLoanscreenId + "gr_row_33").removeClass("sno");
    }else {
        ApzCOB.launchMicroApp("NEWLOA", "NewLoanApplication", "APZCBO__BaseScreens__BaseDIV", KendraApp.selectedCustomer);
        isMahiFromDashboard = true;
        $("#" + newLoanscreenId + "gr_row_33").addClass("sno");
    }
}
apz.app.NewLoanApplication.proceedLead = function(customer) {
    var req = {
        "apiRequest": {
            "interfaceName": "UpdateMahiLeadsStatus",
            "appId": "APZCBO",
            "userId": LoggedInUserDetails.userID,
            "requestObj": {
                "transactionId": $('#NEWLOA__NewLoanApplication__leadTransactionId').text(),
                "status": "Approved"
            }
        }
    }
    apz.startLoader();
    ApzCOB.serverBuildParam(gAppId, "UpdateMahiLeadsStatus", "N", "N", req, false, apz.app.NewLoanApplication.proceedLeadCB);
}
apz.app.NewLoanApplication.proceedLeadCB = function(params) {
     try {
        if (ApzCOB.handleServiceCallBacks(params)) {
            if (!apz.isNull(params.res.APZCBO__UpdateMahiLeadsStatus_Res.apiResponse.ResponseBody.responseObj)) {
                 apz.stopLoader();
                let response = JSON.parse(params.res.APZCBO__UpdateMahiLeadsStatus_Res.apiResponse.ResponseBody.responseObj);
                if(response.message === 'Status changed'){
                   ApzCOB.fnDisplayMsg("Lead Updated Successfully", "S",apz.app.NewLoanApplication.proceedMahiLeadCB);
                   KendraApp.MahiLeadList.forEach(item => {
                        if(item.customerId === mahiLeadData.customerId){
                            item.mahiLeads[0].leadStatus = 'Approved';
                        }
                   });
                }else{
                    apz.stopLoader();
                    ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
                }
                
            } else {
                apz.stopLoader();
                ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
            }
        } else{
            apz.stopLoader();
            ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
        }
    } catch (e) {
        apz.stopLoader();
        ApzCOB.fnDisplayMsg(ApzCOB.getDescfromLitCode("LIT_COMM_ERR_TXT_TECHNICAL"), "E");
    }
}
apz.app.NewLoanApplication.proceedMahiLeadCB = function (params) {
    if (params.choice === true) {
        $('#APZCBO__BaseScreens__BaseDIV').addClass('sno');
        isMahiLeadFromDtlsToLoanInput = true;
        ApzCOB.launchMicroApp("NEWLOA", "AddLoanDetails", "APZCBO__BaseScreens__STAGE1", KendraApp.selectedCustomer);
    }
}
apz.app.NewLoanApplication.mahiLeadToCustomer = function(pthis) {
    event.preventDefault();
    event.stopPropagation();
    let rowNo = $(pthis).attr('rowno');
    viewCustomer = true;
    var selData =  apz.data.scrdata.NEWLOA__MahiLeadList_Res.Lead[rowNo];
    let selectedData = {};
    selectedData.scr = 'KmMahiLeadList'
    selectedData.childScrId = apz.currAppId;
    window.isViewCustFromKMLead = true
    isViewCustFromKMLeadList = true;
    selectedDataFromLoanKMLead = selectedData;
    ApzCOB.FetchCustomerDetails(selData.customerId);
}
