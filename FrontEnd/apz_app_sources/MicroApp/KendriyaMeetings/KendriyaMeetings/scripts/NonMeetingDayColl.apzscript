}
apz.app.NonMeetingDayColl.onClickOfSearchKendra = function(pthis) {
    var searchText = $("#" + pthis.id).val().trim().toLowerCase();
    let searchRec = [];
    let outputArray = cusDetails;
    if (!searchText) {
        apz.data.scrdata.KenMet__IPaintNonKendMeeting_Res.GroupsCustomerDet = outputArray;
        apz.data.loadData('IPaintNonKendMeeting', 'KenMet');
        document.getElementById(nonMetColScrId + 'noRecFound').classList.add('sno');
        document.getElementById(nonMetColScrId + 'row_gorupsDataRow').classList.remove('sno');
        return;
    }
    outputArray.forEach((d) => {
        let custName = (d.customerName || "").toLowerCase();
        let idStr = (d.id || "").toString().toLowerCase();
        if (custName.includes(searchText) || idStr.includes(searchText)) {
            searchRec.push(d);
        }
    });
     if (searchRec.length === 0) {
         document.getElementById(nonMetColScrId + 'row_gorupsDataRow').classList.remove('sno');
         document.getElementById(nonMetColScrId + 'groupDataDiv').classList.add('sno');
         document.getElementById(nonMetColScrId + 'noRecDiv').classList.remove('sno');
         document.getElementById(nonMetColScrId + 'calculatorRow').classList.add('sno');
     } else {
         document.getElementById(nonMetColScrId + 'row_gorupsDataRow').classList.remove('sno');
         document.getElementById(nonMetColScrId + 'groupDataDiv').classList.remove('sno');
         document.getElementById(nonMetColScrId + 'noRecDiv').classList.add('sno');
         document.getElementById(nonMetColScrId + 'calculatorRow').classList.remove('sno');
         apz.data.scrdata.KenMet__IPaintNonKendMeeting_Res.GroupsCustomerDet = searchRec;
         apz.data.loadData('IPaintNonKendMeeting', 'KenMet');
     }
}
apz.app.NonMeetingDayColl.loadCollCustDetials = function(custDetails) {
    if (custDetails.length > 0) {
        document.getElementById(nonMetColScrId + 'custDetails').classList.add('sno');
        document.getElementById(nonMetColScrId + 'row_gorupsDataRow').classList.remove('sno');
        document.getElementById(nonMetColScrId + 'row_groupsHeader').classList.remove('sno');
        document.getElementById(nonMetColScrId + 'launchNextScrDiv').classList.remove('sno');
        document.getElementById(nonMetColScrId + 'noRecDiv').classList.add('sno');
        document.getElementById(nonMetColScrId + "calculatorRow").classList.remove("sno");
        document.getElementById(nonMetColScrId + 'lst_col_groupMainList').classList.remove('sno');
        nmCurrState = 'GroupDataStage';
        let paintArr = [];
        paintArr = apz.app.NonMeetingDayColl.formatCollectionDts(custDetails);
        apz.data.scrdata.KenMet__IPaintNonKendMeeting_Res.GroupsCustomerDet = [];
        apz.data.scrdata.KenMet__IPaintNonKendMeeting_Res.GroupsCustomerDet = paintArr;
        cusDetails = apz.data.scrdata.KenMet__IPaintNonKendMeeting_Res.GroupsCustomerDet;
        isgroupAllPresent = false;
        let [netDue, parAmt, totCollAmt, totalAdv, totalDue] = Array(5).fill(0);
        var nonMeetingData = apz.data.scrdata.KenMet__IPaintNonKendMeeting_Res.GroupsCustomerDet;
        var groups = [];
        nonMeetingData.forEach(function(cust) {
            var groupFound = false;
            groups.forEach(function(grp) {
                if (grp.id === cust.groupId) {
                    grp.members.push({
                        customerName: cust.customerName,
                        id: cust.id,
                        name: cust.name,
                        totalAdv: cust.totalAdv,
                        netDue: cust.netDue || 0,
                        collAmount: cust.collAmount || 0,
                        parFlg: cust.parFlg,
                        parAmt: cust.parAmt || 0,
                        advAmt: cust.advAmt || 0,
                        outstandingAmt: cust.outstandingAmt,
                        depname: cust.depname,
                        cashCollected: cust.cashCollected,
                        dueAmount: cust.dueAmount || 0,
                        loans: Array.isArray(cust.loans) ? cust.loans : [],
                        groupId: cust.groupId,
                        groupName: cust.groupName,
                        kendraId: cust.kendraId,
                        collId: cust.collId,
                        meetingDate: cust.meetingDate,
                        totalDue: cust.totalDue || 0,
                    });
                    groupFound = true;
                }
            });
            if (groupFound === false) {
                groups.push({
                    id: cust.groupId,
                    members: [{
                        customerName: cust.customerName,
                        id: cust.id,
                        name: cust.name,
                        totalAdv: cust.totalAdv,
                        netDue: cust.netDue || 0,
                        collAmount: cust.collAmount || 0,
                        parFlg: cust.parFlg,
                        parAmt: cust.parAmt || 0,
                        advAmt: cust.advAmt || 0,
                        outstandingAmt: cust.outstandingAmt,
                        depname: cust.depname,
                        cashCollected: cust.cashCollected,
                        dueAmount: cust.dueAmount || 0,
                        loans: Array.isArray(cust.loans) ? cust.loans : [],
                        groupId: cust.groupId,
                        groupName: cust.groupName,
                        kendraId: cust.kendraId,
                        collId: cust.collId,
                        meetingDate: cust.meetingDate,
                        totalDue: cust.totalDue || 0,
                    }],
                    netDue: 0,
                    totCollAmt: 0,
                    totalAdv: 0,
                    totalDue: 0,
                    parAmt: 0,
                    totalCash: 0
                });
            }
        });
        console.log(groups);
        kendraGroupMembers = []
        kendraGroups = [];
        let members = [];
        kendraGroups = groups;
        members = [];
        paintGrpsData = [];
        kendraGroups.forEach((grp, j) => {
            let groupMems = [];
            let obj = {};
            obj.id = grp.id;
            obj.netDue = grp.netDue;
            obj.parAmt = grp.parAmt;
            obj.totCollAmt = grp.totCollAmt;
            obj.totalAdv = grp.totalAdv;
            obj.totalDue = grp.totalDue;
            groupMems = grp.members;
            netDue = netDue + grp.netDue;
            parAmt = parAmt + grp.parAmt;
            totCollAmt = totCollAmt + grp.totCollAmt;
            totalAdv = totalAdv + grp.totalAdv;
            totalDue = netDue + grp.totalDue;
            if (grp.hasOwnProperty("totCollAmt")) {
                members = [...members, groupMems];
                paintGrpsData = [...paintGrpsData, obj];
            }
        });
        if (paintGrpsData.length > 1) {
            let allGrpsObj = {};
            allGrpsObj.id = '';
            allGrpsObj.netDue = netDue;
            allGrpsObj.parAmt = parAmt || 0;
            allGrpsObj.totCollAmt = totCollAmt;
            allGrpsObj.totalAdv = totalAdv;
            allGrpsObj.totalDue = totalDue;
            paintGrpsData.unshift(allGrpsObj);
        }
        kendraGroupMembers = members.flat();
        var kendraId = zeroCollData[0].kendraId;
        var exists = kendraNonMeetGroups.some(k => k.kendraId === kendraId);
        if (!exists) {
            var kendraObj = {
                kendraId: kendraId,
                groups: kendraGroups
            };
            kendraNonMeetGroups.push(kendraObj);
            localStorage.setItem('kendraNonMeetGroups', JSON.stringify(kendraNonMeetGroups));
        }
        apz.data.scrdata.KenMet__IPaintNonMeetGrpData_Res = [];
        apz.data.scrdata.KenMet__IPaintNonMeetGrpData_Res = paintGrpsData;
        apz.data.loadData('IPaintNonMeetGrpData', 'KenMet');
        apz.data.loadData('IPaintNonKendMeeting', 'KenMet');
        setTimeout(() => {
            apz.app.NonMeetingDayColl.showMembersEditData(kendraGroupMembers);
        }, 0);
        if (paintGrpsData.length > 1) {
             isgroupAllPresent = true;
             $('#KenMet__IPaintNonMeetGrpData__o__KenMet__IPaintNonMeetGrpData_Res__id_0').addClass('sno');
             $('#' + nonMetColScrId + 'txt_col_grpDescId_0').text('All')
         } else {
             isgroupAllPresent = false;
         }
         if (paintGrpsData.length > 1) {
             isgroupAllPresent = true;
             $('#' + nonMetColScrId + 'lst_paintGrpList li').removeClass('active');
             document.getElementById(nonMetColScrId + "lst_paintGrpList_row_0").classList.add('active');
             $('#KenMet__IPaintNonMeetGrpData__o__KenMet__IPaintNonMeetGrpData_Res__id_0').addClass('sno');
             $('#' + nonMetColScrId + 'txt_col_grpDescId_0').text('All');
             for (let r = 1; r <= paintGrpsData.length; r++) {
                 $('#' + nonMetColScrId + 'txt_col_grpDescId_' + r).text(ApzCOB.getDescfromLitCode('LIT_COL_LBL_gr'));
                 $('#KenMet__IPaintNonMeetGrpData__o__KenMet__IPaintNonMeetGrpData_Res__id_' + r).removeClass('sno');
             }
         } else {
             isgroupAllPresent = false;
             $('#' + nonMetColScrId + 'txt_col_grpDescId_0').text(ApzCOB.getDescfromLitCode('LIT_COL_LBL_gr'));
             $('#KenMet__IPaintNonMeetGrpData__o__KenMet__IPaintNonMeetGrpData_Res__id_0').removeClass('sno');
         }
        document.getElementById(nonMetColScrId + "txt_cashToCollect").innerText = 0;
        document.getElementById(nonMetColScrId + "txt_headerDueAmt").innerText = selectedKendra.kendraName;
        document.getElementById(nonMetColScrId + "txt_UPICollection").innerText = 0;
        for (let i = 0; i < paintArr.length; i++) {
            let selLiDiv = document.querySelector('#' + nonMetColScrId + 'lst_col_groupMainList_row_' + i);
            selLiDiv.querySelector("#" + nonMetColScrId + 'row_partialBalMainRow_row').classList.add('sno');
            // document.getElementById('KenMet__IPaintNonKendMeeting__o__GroupsCustomerDet__cashCollected_' + i).value = (paintArr[i].collAmount);
            document.getElementById('KenMet__IPaintNonKendMeeting__o__GroupsCustomerDet__cashCollected_' + i).value = 0;
            document.getElementById(nonMetColScrId + 'txt_col_memParFlag_' + i).classList.add('sno');
            $("#" + nonMetColScrId + 'txt_col_memParFlag_' + i).removeClass('bg-dark-err');
            document.getElementById(nonMetColScrId + 'icn_coll_infoErrorIcon_' + i).classList.add('sno');
            $('#' + nonMetColScrId + 'qrScanIcon_' + selCustRowNo).attr('data-disabled', false);
            if (paintArr[i].hasOwnProperty('totalAdv')) {
                if (paintArr[i].totalAdv > 0) {
                    document.getElementById(nonMetColScrId + 'txt_custAdvAmt_' + i).closest('.srb').classList.remove('sno');
                    document.getElementById(nonMetColScrId + 'txt_custAdvAmt_' + i).innerText = "₹" + ApzCOB.fn_FormatAmount(paintArr[i].totalAdv) +
                        " Adv. ";
                    let netDueAmt = Number(paintArr[i].netDue) || 0;
                    document.getElementById(nonMetColScrId + 'txt_custNetDueAmt_' + i).innerText = "(Net Due ₹" + ApzCOB.fn_FormatAmount(netDueAmt) +")";
                } else{
                    document.getElementById(nonMetColScrId + 'txt_custAdvAmt_' + i).closest('.srb').classList.add('sno');
                }
            }
        }
        // let btn = document.getElementById(nonMetColScrId + "nonMetColSubBtn");
        // if (btn) {
        //     btn.disabled = true;
        // }
    } else {
        document.getElementById(nonMetColScrId + 'noRecDiv').classList.remove('sno');
        document.getElementById(nonMetColScrId + "calculatorRow").classList.add("sno");
        document.getElementById(nonMetColScrId + 'lst_col_groupMainList').classList.add('sno');
    }
}

apz.app.NonMeetingDayColl.onClickOfGroups = function(pthis) {
    selGrpRowNo = $(pthis).attr('rowno');
    let selGrpData = [];
    let selGrpNo = "";
    let totalCollectedAmt = 0;
    let selGrpId = "";
    let groupAmt = 0;
    let upiTotal = 0;
    let groupsUpi;
    let selKendraDet = {};
    let groupsCash;
    selKendraDet.groups = kendraGroups;
    if (!$('#' + pthis.id).hasClass('active')) {
        $('#' + nonMetColScrId + 'lst_paintGrpList li').removeClass('active');
        $('#' + pthis.id).addClass('active');
        if (selGrpRowNo == "0") {
            let mem = [];
            let ken = [];
            ken = kendraGroups;
            ken.forEach((grp, j) => {
                let groupMems = [];
                groupMems = grp.members;
                mem = [...mem, groupMems];
            })
            console.log(mem);
            ken = mem.flat();
            apz.app.NonMeetingDayColl.loadGroupsData(ken);
        } else {
            selGrpNo = $('#KenMet__IPaintNonMeetGrpData__o__KenMet__IPaintNonMeetGrpData_Res__id_' + selGrpRowNo).text();
            selGrpData = JSON.parse(JSON.stringify(selKendraDet.groups.filter(obj => obj.id === selGrpNo)[0].members));
            selGrpId = selKendraDet.groups.filter(obj => obj.id === selGrpNo)[0].id;
            apz.app.NonMeetingDayColl.loadGroupsData(selGrpData);
        }
        if (apz.data.scrdata.KenMet__IPaintNonMeetGrpData_Res.length > 1 && selGrpRowNo == "0") {
            isgroupAllPresent = true;
            selKendraDet.groups.forEach((group, j) => {
                group.members.forEach((mem, k) => {
                    groupAmt += parseInt(String(mem.collAmount)) || 0;
                })
            });
            selKendraDet.groups.forEach((group, j) => {
                group.members.forEach((mem, k) => {
                    upiTotal += parseInt(String(mem.upiCollected)) || 0;
                });
            })
            document.getElementById(nonMetColScrId + "txt_UPICollection").innerText = ApzCOB.fn_FormatAmount(upiTotal);
            document.getElementById(nonMetColScrId + "txt_cashToCollect").innerText = ApzCOB.fn_FormatAmount(groupAmt - upiTotal);
        } else {
            isgroupAllPresent = false;
            groupsCash = selKendraDet.groups.filter(obj => obj.id === selGrpNo);
            groupsCash[0].members.forEach((mem, k) => {
                groupAmt += parseInt(String(mem.collAmount)) || 0;
            });
            groupsUpi = selKendraDet.groups.filter(obj => obj.id == selGrpNo);
            groupsUpi[0].members.forEach((mem, k) => {
                upiTotal += parseInt(String(mem.upiCollected)) || 0;
            });
            document.getElementById(nonMetColScrId + "txt_UPICollection").innerText = ApzCOB.fn_FormatAmount(upiTotal);
            document.getElementById(nonMetColScrId + "txt_cashToCollect").innerText = ApzCOB.fn_FormatAmount(groupAmt - upiTotal);
        }
    }
}
apz.app.NonMeetingDayColl.showMembersEditData = function(customers) {
    customers.forEach( (obj, i) => {
        // if (obj.parFlg === "Y") {
        //     document.getElementById(nonMetColScrId + 'txt_col_memParFlag_' + i).classList.remove('sno');
        //     $("#" + nonMetColScrId + 'txt_col_memParFlag_' + i).addClass('bg-dark-err');
        //     document.getElementById(nonMetColScrId + 'icn_coll_infoErrorIcon_' + i).classList.remove('sno');
        // } else {
        //     document.getElementById(nonMetColScrId + 'txt_col_memParFlag_' + i).classList.add('sno');
        //     $("#" + nonMetColScrId + 'txt_col_memParFlag_' + i).removeClass('bg-dark-err');
        //     document.getElementById(nonMetColScrId + 'icn_coll_infoErrorIcon_' + i).classList.add('sno');
        // }
        // obj.loans.forEach((loanObj, j) => {
        // })

        document.getElementById(nonMetColScrId + 'txt_afterAmountId_' + i).innerText = ')';
        document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).classList.remove("inf");
        document.getElementById(nonMetColScrId + 'txt_afterAmountId_' + i).classList.remove("inf");
        document.getElementById(nonMetColScrId + 'txt_parAdvRupeeSym_' + i).classList.remove("inf");
        document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).closest('.srb').classList.add('sno');
        $('#KenMet__IPaintNonKendMeeting__o__GroupsCustomerDet__cashCollected_' + i).closest('.scb-col65').removeClass('sno');
        $('#' + nonMetColScrId + 'txt_QRAmtPostAdd_' + i).closest('.coll-upiamt').addClass('sno');
        $('#' + nonMetColScrId + 'txt_UPIInProgressErrTxt_' + i).closest('.coll-upiamt').addClass('sno');
        $('#' + nonMetColScrId + 'txt_UPIFailedErrTxt_' + i).parent().parent().addClass('sno');
        $('#KenMet__IPaintNonKendMeeting__o__GroupsCustomerDet__cashCollected_' + i).attr('disabled', false);
        // $('#' + nonMetColScrId + 'qrScanIcon_' + i).attr('data-disabled', false);
        document.getElementById(nonMetColScrId + 'txt_custAdvAmt_' + i).closest('.srb').classList.add('sno');
        // if (parseInt(String(obj.outstandingAmt).replace(/,/g, ''), 10) === 0 && parseInt(String(obj.totalDue).replace(/,/g, ''), 10) <=
        //     parseInt(String(obj.cashCollected).replace(/,/g, ''), 10)) {
        if (parseInt(String(obj.outstandingAmt).replace(/,/g, ''), 10) === 0 && parseInt(String(obj.totalDue ?? 0).replace(/,/g, ''), 10) === 0) {
            $('#KenMet__IPaintNonKendMeeting__o__GroupsCustomerDet__cashCollected_' + i).attr('disabled', true);
            $('#' + nonMetColScrId + 'qrScanIcon_' + i).attr('data-disabled', true);
            document.getElementById(nonMetColScrId + 'qrScanIcon_' + i).style.opacity = 0.4;
            document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).closest('.srb').classList.add('sno');
        } else if ((obj.hasOwnProperty('upiCollected') && parseInt(String(obj.upiCollected).replace(/,/g, ''), 10) > 0) || (obj.hasOwnProperty('totalUPI') && parseInt(String(obj.totalUPI).replace(/,/g, ''), 10) > 0)) {
            $('#KenMet__IPaintNonKendMeeting__o__GroupsCustomerDet__cashCollected_' + i).attr('disabled', true);
            $('#KenMet__IPaintNonKendMeeting__o__GroupsCustomerDet__cashCollected_' + i).val(obj.upiCollected || 0);
            // $('#' + EditGrpDataScrId + 'qrScanIcon_' + i).attr('data-disabled', true);
            if (obj.UPIStatus === "INPROGRESS") {
                $('#' + nonMetColScrId + 'txt_QRAmtPostAdd_' + i).closest('.coll-upiamt').addClass('sno');
                $('#' + nonMetColScrId + 'txt_UPIInProgressErrTxt_' + i).closest('.coll-upiamt').removeClass('sno');
            } else if (obj.UPIStatus === "FAILED") {
                $('#' + nonMetColScrId + 'txt_QRAmtPostAdd_' + i).closest('.coll-upiamt').addClass('sno');
                $('#' + nonMetColScrId + 'txt_UPIFailedErrTxt_' + i).parent().parent().removeClass('sno');
                $("#" + nonMetColScrId + "btn_upiRetryBtn_" + i).attr('disabled', false);
            } else if (obj.UPIStatus === "SUCCESS" || obj.paymentFlg === "UPI") {
                $('span[id="KenMet__NonMeetingDayColl__sc_col_184_li"]').eq(i).removeClass('sno');
                document.getElementById(nonMetColScrId + 'icn_coll_infoErrorIcon_' + i).classList.remove('sno');
                $('#' + nonMetColScrId + 'txt_QRAmtPostAdd_' + i).closest('.coll-upiamt').removeClass('sno');
                $('#' + nonMetColScrId + 'txt_QRAmtPostAdd_' + i).text(obj.upiCollected !== undefined ? obj.upiCollected : obj.totalUPI);
                $('#KenMet__NonMeetingDayColl__row_col_paidUPIAmt_row_' + i).removeClass('sno');
            }
            $('#' + nonMetColScrId + 'qrScanIcon_' + i).addClass('sno');
            $('#KenMet__IPaintNonKendMeeting__o__GroupsCustomerDet__cashCollected_' + i).closest('.scb-col65').addClass('sno');
        } else if ((obj.hasOwnProperty('cashCollected') && parseInt(String(obj.cashCollected).replace(/,/g, ''), 10) > 0) || (obj.hasOwnProperty('totalCash') && parseInt(String(obj.totalCash).replace(/,/g, ''), 10) > 0)) {
            $('#KenMet__IPaintNonKendMeeting__o__GroupsCustomerDet__cashCollected_' + i).closest('.scb-col65').removeClass('sno');
            $('#KenMet__IPaintNonKendMeeting__o__GroupsCustomerDet__cashCollected_' + i).attr('disabled', false);
            document.getElementById('KenMet__IPaintNonKendMeeting__o__GroupsCustomerDet__cashCollected_' + i).value = ApzCOB.fn_FormatAmount(obj.collAmount);
            $('#' + nonMetColScrId + 'qrScanIcon_' + i).attr('data-disabled', true);
            document.getElementById(nonMetColScrId + 'qrScanIcon_' + i).style.opacity = 0.4;
            $('#' + nonMetColScrId + 'txt_QRAmtPostAdd_' + i).closest('.coll-upiamt').addClass('sno');
            if (obj.loans.length > 0) {
                let CashAmtPresent = (obj.loans).some(loan => loan.cashAmt > 0);
                if (CashAmtPresent) {
                    $('#' + nonMetColScrId + 'qrScanIcon_' + i).attr('data-disabled', true);
                    document.getElementById(nonMetColScrId + 'qrScanIcon_' + i).style.opacity = 0.4;
                }
            }
        }
        if (obj.collAmount < obj.totalDue ?? 0) {
            if (obj.totalAdv > 0 || (obj.hasOwnProperty('advAdj') && obj.advAdj > 0)) {
                document.getElementById(nonMetColScrId + 'txt_custAdvAmt_' + i).closest('.srb').classList.remove('sno');
                let tempPrevAdvAmt = obj.totalAdv > 0 ? obj.totalAdv : obj.advAdj;
                document.getElementById(nonMetColScrId + 'txt_custAdvAmt_' + i).innerText = "₹" + ApzCOB.fn_FormatAmount(tempPrevAdvAmt) + " Adv. ";
                document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).classList.add("inf");
                document.getElementById(nonMetColScrId + 'txt_afterAmountId_' + i).classList.add("inf");
                document.getElementById(nonMetColScrId + 'txt_parAdvRupeeSym_' + i).classList.add("inf");
                document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).classList.remove("war");
                document.getElementById(nonMetColScrId + 'txt_afterAmountId_' + i).classList.remove("war");
                document.getElementById(nonMetColScrId + 'txt_parAdvRupeeSym_' + i).classList.remove("war");
            } else {
                document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).closest('.srb').classList.add('sno');
                document.getElementById('KenMet__IPaintNonKendMeeting__o__GroupsCustomerDet__cashCollected_' + i).value = ApzCOB.fn_FormatAmount(obj.collAmount);
                document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).innerText = (obj.netDue - obj.collAmount);
                document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).classList.remove("inf");
                document.getElementById(nonMetColScrId + 'txt_afterAmountId_' + i).classList.remove("inf");
                document.getElementById(nonMetColScrId + 'txt_parAdvRupeeSym_' + i).classList.remove("inf");
                document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).classList.add("war");
                document.getElementById(nonMetColScrId + 'txt_afterAmountId_' + i).classList.add("war");
                document.getElementById(nonMetColScrId + 'txt_parAdvRupeeSym_' + i).classList.add("war");
                document.getElementById(nonMetColScrId + 'txt_partialAmtText_' + i).classList.remove('sno');
                document.getElementById(nonMetColScrId + 'icn_coll_infoErrorIcon_' + i).classList.remove('sno');
            }
        } else if (obj.totalAdv > 0 || obj.advAdj > 0) {
            document.getElementById(nonMetColScrId + 'txt_custAdvAmt_' + i).closest('.srb').classList.remove('sno');
            let tempPrevAdvAmt = obj.totalAdv > 0 ? obj.totalAdv : obj.advAdj;
            document.getElementById(nonMetColScrId + 'txt_custAdvAmt_' + i).innerText = "₹" + ApzCOB.fn_FormatAmount(tempPrevAdvAmt) + " Adv. ";
            document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).classList.add("inf");
            document.getElementById(nonMetColScrId + 'txt_afterAmountId_' + i).classList.add("inf");
            document.getElementById(nonMetColScrId + 'txt_parAdvRupeeSym_' + i).classList.add("inf");
            document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).classList.remove("war");
            document.getElementById(nonMetColScrId + 'txt_afterAmountId_' + i).classList.remove("war");
            document.getElementById(nonMetColScrId + 'txt_parAdvRupeeSym_' + i).classList.remove("war");
        }
        if (obj.advAmt > 0) {
            document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).closest('.srb').classList.remove('sno');
            document.getElementById(nonMetColScrId + 'txt_partialAmtText_' + i).classList.add('sno');
            // document.getElementById(EditGrpDataScrId + 'icn_coll_infoErrorIcon_' + i).classList.add('sno');
            document.getElementById(nonMetColScrId + 'txt_afterAmountId_' + i).innerText = 'Advance';
            document.getElementById(nonMetColScrId + 'txt_afterAmountId_' + i).classList.add("inf");
            document.getElementById(nonMetColScrId + 'txt_parAdvRupeeSym_' + i).classList.add("inf");
            document.getElementById(nonMetColScrId + 'txt_parAdvRupeeSym_' + i).classList.remove("war");
            document.getElementById(nonMetColScrId + 'txt_afterAmountId_' + i).classList.remove("war");
            document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).innerText = obj.advAmt;
            document.getElementById(nonMetColScrId + 'txt_partialAmtPaintId_' + i).classList.add("inf");
        }
        if (obj.totalAdv > 0) {
            document.getElementById(nonMetColScrId + 'txt_custAdvAmt_' + i).closest('.srb').classList.remove('sno');
            document.getElementById(nonMetColScrId + 'txt_custAdvAmt_' + i).innerText = "₹" + ApzCOB.fn_FormatAmount(obj.totalAdv) + " Adv. ";
            document.getElementById(nonMetColScrId + 'txt_custNetDueAmt_' + i).innerText = "(Net Due ₹" + ApzCOB.fn_FormatAmount(obj.netDue) + ")"
        }
        if (Number(obj.cashCollected) == 0 && Number(obj.collAmount) == 0 && (Number(obj.upiCollected) == 0 || obj.upiCollected == undefined)) {
            document.getElementById(nonMetColScrId + 'icn_coll_infoErrorIcon_' + i).classList.add('sno');
        }
        if (Number(obj.totalDue) == 0 && Number(obj.outstandingAmt.replace(/,/g, '')) > 0 && Number(obj.cashCollected) == 0 && Number(obj.collAmount) == 0 ) {
            $('#' + nonMetColScrId + 'qrScanIcon_' + i).removeClass('sno');
            $('#' + nonMetColScrId + 'qrScanIcon_' + i).attr('data-disabled', false);
            document.getElementById(nonMetColScrId + 'qrScanIcon_' + i).style.opacity = 1;
        } else if (Number(obj.totalDue) > 0 && Number(obj.outstandingAmt.replace(/,/g, '')) > 0 && Number(obj.cashCollected) == 0 && Number(obj.collAmount) == 0  ) {
            $('#' + nonMetColScrId + 'qrScanIcon_' + i).removeClass('sno');
            $('#' + nonMetColScrId + 'qrScanIcon_' + i).attr('data-disabled', false);
            document.getElementById(nonMetColScrId + 'qrScanIcon_' + i).style.opacity = 1;
        } else if ((Number(obj.totalDue) > 0 || Number(obj.totalDue) == 0) && Number(obj.outstandingAmt.replace(/,/g, '')) > 0 && Number(obj.cashCollected) == 0 && Number(obj.collAmount) == 0 ) {
            $('#' + nonMetColScrId + 'qrScanIcon_' + i).removeClass('sno');
        }
        if (currentUserRole == 'DEO') {
            if ((!apz.isNull(KendraApp.selectedKendra.customerDtls)) && KendraApp?.selectedKendra?.customerDtls?.length > 0) {
                let selectedCustomer = KendraApp.selectedKendra?.customerDtls.find(cust => cust.customerId == obj.id);
                if ((!apz.isNull(selectedCustomer)) && (selectedCustomer?.hasOwnProperty("custStatus") || selectedCustomer?.hasOwnProperty("newCustStatus"))) {
                    if (selectedCustomer?.custStatus?.includes('MAHI') || selectedCustomer?.newCustStatus?.includes('MAHI')) {
                        document.getElementById(nonMetColScrId + 'mahiFlag_' + i).classList.remove("sno");
                    } else {
                        document.getElementById(nonMetColScrId + 'mahiFlag_' + i).classList.add("sno");
                    }
                } else {
                    document.getElementById(nonMetColScrId + 'mahiFlag_' + i).classList.add("sno");
                }
            }
        } else {
            if ((!apz.isNull(mahiFlagCustData.kendraDtls.customerDtls)) && mahiFlagCustData?.kendraDtls?.customerDtls?.length > 0) {
                let selectedCustomer = mahiFlagCustData?.kendraDtls?.customerDtls.find(cus => cus.customerId == obj.id);
                if ((!apz.isNull(selectedCustomer)) && (selectedCustomer?.hasOwnProperty("custStatus") || selectedCustomer?.hasOwnProperty("newCustStatus"))) {
                    if (selectedCustomer?.custStatus?.includes('MAHI') || selectedCustomer?.newCustStatus?.includes('MAHI')) {
                        document.getElementById(nonMetColScrId + 'mahiFlag_' + i).classList.remove("sno");
                    } else {
                        document.getElementById(nonMetColScrId + 'mahiFlag_' + i).classList.add("sno");
                    }
                } else {
                    document.getElementById(nonMetColScrId + 'mahiFlag_' + i).classList.add("sno");
                }
            }
        }
    }
    );
}


