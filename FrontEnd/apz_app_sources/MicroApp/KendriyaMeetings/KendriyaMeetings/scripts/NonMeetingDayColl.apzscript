}
apz.app.NonMeetingDayColl.timerEnd = function() {
    if (apz.childScr === 'NonMeetingDayColl') {
        //   if (window.otpRegenCount !== RegenCount) {
        $("#" + nonMetColScrId + "row_col_Regenerateotp").removeClass("sno");
        document.getElementById(nonMetColScrId + 'gensuccqr').style.opacity = 0.1;
        $("#" + nonMetColScrId + "col_row_expiryDIV").addClass("sno");
        $("#" + nonMetColScrId + "row_scanQrCodeLabelRow").addClass('sno');
        if (isAmtOrQRText === "QR") {
            clearInterval(QRStatusTimerInterval);
        }
        apz.app.NonMeetingDayColl.handleExpiredQR();
       
    }
}
apz.app.NonMeetingDayColl.handleExpiredQR = function() {
    let li = document.getElementById('KenMet__NonMeetingDayColl__gensuccqr_li');
    let qrImg = document.getElementById('KenMet__NonMeetingDayColl__gensuccqr');
    let overlay = li.querySelector('.qr-expired-overlay');
    if (!overlay) {
        overlay = document.createElement('div');
        overlay.className = 'qr-expired-overlay';
        overlay.innerText = 'QR Expired';
        overlay.style.cssText = `
            position:absolute;
            top:0;
            left:0;
            width:100%;
            height:100%;
            color:red;
            font-size:18px;
            display:flex;
            justify-content:center;
            align-items:center;
            font-weight:bold;
            z-index:10;
            display:none;
        `;
        li.appendChild(overlay);
    }
    let blocker = li.querySelector('.qr-expired-blocker');
    if (!blocker) {
        blocker = document.createElement('div');
        blocker.className = 'qr-expired-blocker';
        blocker.style.cssText = `
            position:absolute;
            top:35%;
            left:35%;
            width:30%;
            height:30%;
            background:white;
            z-index:9;
            display:none;
        `;
        li.appendChild(blocker);
    }
    overlay.style.display = 'flex';
    blocker.style.display = 'block';
    qrImg.style.opacity = '0.3';
    document.body.classList.add('mdl-opn');
}
apz.app.NonMeetingDayColl.onAmtEntryModalClose = function() {
    if ($('#KenMet__NonMeetingDayColl__frm_qrImageForm').is(':visible')) {
        clearInterval(QRStatusTimerInterval);
        clearInterval(selInterval);
        selectedCustomerDetails.upiCollected = '0';
        if (selectedCustomerDetails?.parFlg == 'N') {
            selectedCustomerDetails.cashCollected = selectedCustomerDetails.dueAmount;
            selectedCustomerDetails.collAmount = selectedCustomerDetails.netDue;
        } else if (selectedCustomerDetails?.parFlg == 'Y') {
            selectedCustomerDetails.cashCollected = '0';
            selectedCustomerDetails.collAmount = '0';
        }
    }
    if (document.body.classList.contains("mdl-opn")) {
        document.body.classList.remove("mdl-opn");
    }
}
