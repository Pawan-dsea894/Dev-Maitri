apz.app.BstDetails.onSelectedMeetingDayDtls = function() {
    filterdKendraArr = [];
    $("#Widget__InProgress__el_inp_1").val('')
    if(apz.isNull(kendraList)){
        kendraList = [...window.NewloanWidgetKendraArr];
    }
    $.each(apz.data.scrdata.Widget__IPaintWidgetMeetingDay_Res, function(i) {
        if ($('#' + BstDtlsScrId + 'meetingDayCheckBox_' + i).prop('checked')) {
            let selectedMeetingDay = apz.data.scrdata.Widget__IPaintWidgetMeetingDay_Res[i].meetingDay;
            $('#' + BstDtlsScrId + 'meetingDay').val(selectedMeetingDay);
            kendraList.forEach(k=>{
                if($("#Widget__BstDetails__kmId").val() == ''){
                    if(dayMap[k.meetingDay] === selectedMeetingDay){
                        filterdKendraArr.push(k)
                    }
                }else {
                    if(k.kmId === selectedKmId.split('(')[0].trim() && dayMap[k.meetingDay] === selectedMeetingDay){
                        filterdKendraArr.push(k)
                    }
                }
            })
            if(filterdKendraArr?.length > 0){
                apz.data.scrdata.Widget__IPaintNewLoanApplication_Res = {};
                apz.data.scrdata.Widget__IPaintNewLoanApplication_Res.WidgetNewLoan = filterdKendraArr;
                apz.data.loadData('IPaintNewLoanApplication', 'Widget');
                $('#Widget__InProgress__bstSearch').removeClass("sno");
                $('#Widget__InProgress__noRecord').addClass('sno');
                $('#Widget__InProgress__loanApp').removeClass('sno');
            }else{
                apz.data.scrdata.Widget__IPaintNewLoanApplication_Res = {};
                apz.data.scrdata.Widget__IPaintNewLoanApplication_Res.WidgetNewLoan = {};
                $('#Widget__InProgress__loanApp').addClass('sno');
                $('#Widget__InProgress__noRecord').removeClass('sno');
                $('#Widget__InProgress__bstSearch').addClass("sno");
            }
            ApzCOB.toggleModal(BstDtlsScrId + 'MeetingDayModal');
        }
    })
}
apz.app.BstDetails.onSearch = function(pthis) {
    let searchText = $("#" + pthis.id).val();
    let searchResult = [];
    searchArr = [...filterdKendraArr];
    searchArr = searchArr.length>0?searchArr:window.NewloanWidgetKendraArr;
    searchArr.forEach(k=>{
        k.kendraId = k.kendraId.toString();
    })
    searchResult = ApzCOB.arraySearch(searchText, searchArr, ["kendraName","kendraId"],'Widget__IPaintNewLoanApplication_Res', "", '', '');
    searchResult.forEach((item, index) => {
        item.rowNo = index;
    });
    if (searchResult.length === 0) {
        $("#" + InProgressWidgetId + "noRecord").removeClass("sno");
        $("#" + InProgressWidgetId + "loanApp").addClass("sno");
    } else {
        $("#" + InProgressWidgetId + "noRecord").addClass("sno");
        $("#" + InProgressWidgetId + "loanApp").removeClass("sno");
    }
    if (searchText.length === 0) {
        apz.data.scrdata.Widget__IPaintNewLoanApplication_Res.WidgetNewLoan = searchArr;
        apz.data.loadData('IPaintNewLoanApplication', 'Widget');
        $("#" + InProgressWidgetId + "noRecord").addClass("sno");
        $("#" + InProgressWidgetId + "loanApp").removeClass("sno");
    } else {
        apz.data.scrdata.Widget__IPaintNewLoanApplication_Res = {};
        apz.data.scrdata.Widget__IPaintNewLoanApplication_Res.WidgetNewLoan = searchResult;
        apz.data.loadData('IPaintNewLoanApplication', 'Widget');
    }
}
apz.app.BstDetails.searchKendraIdInModal = function(pthis) {
    $.each(apz.data.scrdata.Widget__IPaintWidgetKmIdList_Res, function(i) {
        $('#' + BstDtlsScrId + 'kmIdCheckBox_' + i).prop('checked', false);
    });
    let searchText = $("#" + pthis.id).val();
    let searchResult = [];
    searchResult = ApzCOB.arraySearch(searchText, kmUniqueArr, ["kmId"],'Widget__IPaintWidgetKmIdList_Res', "", '', '');
    searchResult.forEach((item, index) => {
        item.rowNo = index;
    });
    if (searchResult.length === 0) {
        $("#" + BstDtlsScrId + "noRecordForm3").removeClass("sno");
        $("#" + BstDtlsScrId + "kmListRow").addClass("sno");
    } else {
        $("#" + BstDtlsScrId + "noRecordForm3").addClass("sno");
        $("#" + BstDtlsScrId + "kmListRow").removeClass("sno");
    }
    if (searchText.length === 0) {
        apz.data.scrdata.Widget__IPaintWidgetKmIdList_Res = kmUniqueArr;
        apz.data.loadData("IPaintWidgetKmIdList", 'Widget');
        $("#" + BstDtlsScrId + "noRecordForm3").addClass("sno");
        $("#" + BstDtlsScrId + "kmListRow").removeClass("sno");
    } else {
        apz.data.scrdata.Widget__IPaintWidgetKmIdList_Res = {};
        apz.data.scrdata.Widget__IPaintWidgetKmIdList_Res = searchResult;
        apz.data.loadData("IPaintWidgetKmIdList", 'Widget');
    }
}
