let filterdKendraArr = [];
let selectedKmId;
apz.app.BstDetails.onSelectedKmIdDetails = function() {
    filterdKendraArr = [];
    $("#Widget__InProgress__el_inp_1").val('')
    $.each(apz.data.scrdata.Widget__IPaintWidgetMeetingDay_Res, function(i) {
        $('#' + BstDtlsScrId + 'meetingDayCheckBox_' + i).prop('checked', false);
    });
    $('#' + BstDtlsScrId + 'meetingDay').val('')
    $.each(apz.data.scrdata.Widget__IPaintWidgetKmIdList_Res, function(i) {
        if ($('#' + BstDtlsScrId + 'kmIdCheckBox_' + i).prop('checked')) {
            selectedKmId = apz.data.scrdata.Widget__IPaintWidgetKmIdList_Res[i].kmId;
            $('#' + BstDtlsScrId + 'kmId').val(selectedKmId)
            kendraList.forEach(k=>{
                if(k.kmId === selectedKmId.split('(')[0].trim()){
                    filterdKendraArr.push(k)
                }
            })
            if(filterdKendraArr.length > 0){
                apz.data.scrdata.Widget__IPaintNewLoanApplication_Res = {};
                apz.data.scrdata.Widget__IPaintNewLoanApplication_Res.WidgetNewLoan = filterdKendraArr;
                apz.data.loadData('IPaintNewLoanApplication', 'Widget');
                $('#Widget__InProgress__bstSearch').removeClass("sno");
                $('#Widget__InProgress__noRecord').addClass('sno');
                $('#Widget__InProgress__loanApp').removeClass('sno');
            }else{
                apz.data.scrdata.Widget__IPaintNewLoanApplication_Res = {};
                apz.data.scrdata.Widget__IPaintNewLoanApplication_Res.WidgetNewLoan = {};
                $('#Widget__InProgress__loanApp').addClass('sno');
                $('#Widget__InProgress__noRecord').removeClass('sno')
                $('#Widget__InProgress__bstSearch').addClass("sno");
            }
            ApzCOB.toggleModal(BstDtlsScrId + 'KmIdModal');
        }
    })
}
